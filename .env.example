# HubSpot portal 6603479 (NA2). Form GUIDs are not secrets but stay server-side
# so validation and hutk attribution run through our API proxies.

# Contact form (legacy HUBSPOT_FORM_ID still accepted as fallback)
HUBSPOT_FORM_ID_CONTACT=
# HUBSPOT_FORM_ID=

# Newsletter capture (Footer + end-of-blog). Section hidden when unset.
HUBSPOT_FORM_ID_NEWSLETTER=

# Gated white-paper downloads. Section uses registry in src/lib/whitePapers.ts.
HUBSPOT_FORM_ID_WHITEPAPER=

# Careers application form on /about/careers.
HUBSPOT_FORM_ID_CAREERS=

# Meetings scheduler embed URL (e.g. https://meetings-na2.hubspot.com/slug).
# Prefer the hubspot.com host; a branded domain only works if its DNS/TLS is healthy.
# Contact page #book section hidden when unset.
HUBSPOT_MEETINGS_URL=

# Force HubSpot tracker on non-canonical hosts (localhost, *.vercel.app previews).
# Values: unset | force
# NEXT_PUBLIC_HUBSPOT_TRACKING=force
